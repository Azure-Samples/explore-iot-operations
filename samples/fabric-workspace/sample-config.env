# Microsoft Fabric workspace – sample config
#
# Shared by export-fabric-workspace.sh and recreate-fabric-workspace.sh.
# Copy this file, edit it, and pass it with --config my-config.env.

# ── Export settings ────────────────────────────────────────────────────────────
# The workspace to export from
FABRIC_WORKSPACE_ID="00000000-0000-0000-0000-000000000000"

# Where to write / read the snapshot (default: snapshot.json in current directory)
SNAPSHOT_FILE="snapshot.json"

# ── Recreate settings ──────────────────────────────────────────────────────────

# Fabric capacity to assign to the NEW workspace.
# Find yours: az fabric capacity list -o table
FABRIC_CAPACITY_ID=""

# Required: display name for the new workspace
NEW_WORKSPACE_NAME="my-new-workspace"

# Optional: reuse an existing workspace instead of creating a new one
# FABRIC_WORKSPACE_ID="00000000-0000-0000-0000-000000000000"

# ── Event Hubs ─────────────────────────────────────────────────────────────────
# Required to restore the Eventstream source connection.
# Option A – individual fields (easier to fill in):
# EVENTHUB_NAMESPACE="<namespace>"          # namespace name only, no .servicebus.windows.net
# EVENTHUB_ENTITY_PATH="<hub-name>"         # event hub (entity) name
# EVENTHUB_KEY_NAME="RootManageSharedAccessKey"
# EVENTHUB_KEY="<base64-key>"
#
# Option B – full SAS connection string (overrides the individual fields above if set):
# EVENTHUB_CONNECTION_STRING="Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<policy>;SharedAccessKey=<key>;EntityPath=<hub>"
#
EVENTHUB_CONSUMER_GROUP="\$Default"
